{
    "buildCommand": null,
    "outputDirectory": ".",
    "functions": {
      "api/subscribe.js": {
        "memory": 128,
        "maxDuration": 10
      },
      "api/enquete.js": {
        "memory": 128,
        "maxDuration": 10
      }
    },
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/api/$1"
      },
      {
        "src": "/enquete-2026",
        "dest": "/enquete-2026.html"
      },
      {
        "src": "/terrain",
        "dest": "/terrain.html"
      },
      {
        "src": "/(.*)",
        "dest": "/$1"
      },
      { "handle": "error" },
      { "status": 404, "src": "/(.*)", "dest": "/404.html" }
    ]
  }