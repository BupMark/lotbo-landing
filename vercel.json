{
    "buildCommand": null,
    "outputDirectory": ".",
    "functions": {
      "api/subscribe.js": {
        "memory": 128,
        "maxDuration": 10
      },
      "api/enquete.js": {
        "memory": 128,
        "maxDuration": 10
      },
      "api/stripe-webhook.js": {
        "memory": 128,
        "maxDuration": 10
      },
      "api/create-checkout-session.js": {
        "memory": 128,
        "maxDuration": 10
      }
    },
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/api/$1"
      },
      {
        "src": "/enquete-2026",
        "dest": "/enquete-2026.html"
      },
      {
        "src": "/terrain",
        "dest": "/terrain.html"
      },
      {
        "src": "/partenariats",
        "dest": "/partenariats.html"
      },
      {
        "src": "/a-propos",
        "dest": "/a-propos.html"
      },
      {
        "src": "/faq",
        "dest": "/faq.html"
      },
      {
        "src": "/contact",
        "dest": "/contact.html"
      },
      {
        "src": "/supporter-fondateur",
        "dest": "/supporter-fondateur.html"
      },
      {
        "src": "/supporters",
        "dest": "/supporters.html"
      },
      {
        "src": "/legal/cgu",
        "dest": "/legal/cgu.html"
      },
      {
        "src": "/legal/confidentialite",
        "dest": "/legal/confidentialite.html"
      },
      {
        "src": "/legal/moderation",
        "dest": "/legal/moderation.html"
      },
      {
        "src": "/legal/cookies",
        "dest": "/legal/cookies.html"
      },
      {
        "src": "/legal/mentions-legales",
        "dest": "/legal/mentions-legales.html"
      },
      {
        "src": "/(.*)",
        "dest": "/$1"
      },
      { "handle": "error" },
      { "status": 404, "src": "/(.*)", "dest": "/404.html" }
    ]
  }
